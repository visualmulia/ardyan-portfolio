---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('publications');
  return posts.map(post => ({
    params: { slug: post.slug || post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Format Date helper
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout 
    title={`${post.data.title} | Ardyan Dev Publications`} 
    description={post.data.description}
    articleData={{
      title: post.data.title,
      description: post.data.description,
      publishDate: post.data.date,
      slug: post.slug || post.data.slug,
      image: post.data.image
    }}
>
    <!-- Subtle Grid Overlay -->
    <div class="grid-overlay"></div>

    <!-- Background Glows -->
    <div class="cursor-glow" id="custom-cursor-glow"></div>

    <!-- Header / Navbar -->
    <header id="main-header" class="scrolled">
        <div class="container">
            <a href="/" class="logo" id="logo-link">
                &lt;A/&gt; ardyan<span>.web.id</span>
            </a>
            
            <nav>
                <ul id="nav-links">
                    <li><a href="/#about" id="nav-about-link">About</a></li>
                    <li><a href="/#services" id="nav-services-link">Services</a></li>
                    <li><a href="/#portfolio" id="nav-portfolio-link">Portfolio</a></li>
                    <li><a href="/#calculator" id="nav-calculator-link">Calculator</a></li>
                    <li><a href="/publications" class="active" id="nav-publications-link">Publications</a></li>
                    <li><a href="/#faq" id="nav-faq-link">FAQ</a></li>
                    <li><a href="/#contact" class="btn btn-primary nav-cta" id="nav-cta-talk">Let's Talk</a></li>
                </ul>
            </nav>

            <div class="menu-toggle" id="menu-toggle">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </header>

    <main style="padding-top: 140px; min-height: 80vh;">
        <div class="container" style="max-width: 800px; padding: 0 24px;">
            <!-- Back to list link -->
            <a href="/publications" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-ai-indigo); font-weight: 700; text-decoration: none; font-size: 14px; margin-bottom: 32px; transition: all 0.3s ease; position: relative; z-index: 10;" id="back-link" class="back-link-hover">
                <i class="fas fa-arrow-left"></i> Back to Publications
            </a>

            <!-- Article Body Wrapper -->
            <article>
                <div class="article-header" style="margin-bottom: 40px;">
                    <span style="background: rgba(99, 102, 241, 0.08); color: var(--color-ai-indigo); font-weight: 800; font-size: 11px; padding: 6px 14px; border-radius: 12px; border: 1px solid rgba(99, 102, 241, 0.25); text-transform: uppercase; display: inline-block; margin-bottom: 18px; letter-spacing: 0.5px;">
                        {post.data.category}
                    </span>
                    <h1 style="font-family: var(--font-heading); font-size: clamp(28px, 4vw, 44px); font-weight: 900; line-height: 1.25; color: var(--color-text-dark); margin-bottom: 20px;">
                        {post.data.title}
                    </h1>
                    
                    <div style="display: flex; align-items: center; gap: 16px; font-size: 14px; color: var(--color-text-muted-dark); font-weight: 500;">
                        <span>By Ardyan</span>
                        <span style="opacity: 0.3;">//</span>
                        <span><i class="far fa-calendar-alt" style="margin-right: 6px;"></i> {formatDate(post.data.date)}</span>
                    </div>
                </div>

                <!-- Article Cover Image -->
                {post.data.image && (
                  <div style={`background-image: url('${post.data.image}'); height: 400px; background-size: cover; background-position: center; border-radius: 16px; border: 1px solid var(--color-light-border); margin-bottom: 48px;`}></div>
                )}

                <!-- Article Body Content -->
                <div class="article-content" style="color: var(--color-text-dark); font-size: 17px; line-height: 1.8; font-family: var(--font-body);">
                    <Content />
                </div>
            </article>

            <!-- Pre-Footer CTA -->
            <div style="margin-top: 80px; padding: 40px; background: var(--color-light-card); border: 1px solid var(--color-light-border); border-radius: 16px; text-align: center; margin-bottom: 80px;">
                <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 800; color: var(--color-text-dark); margin-bottom: 12px;">Need Custom Systems Built with Speed?</h3>
                <p style="font-size: 15px; color: var(--color-text-muted-dark); max-width: 500px; margin: 0 auto 24px auto;">I build landing pages, SaaS platforms, native mobile apps, and robust automations. Async communication, no meetings.</p>
                <a href="/#contact" class="btn btn-primary" style="display: inline-flex; justify-content: center; align-items: center;">Let's Work Together <i class="fas fa-arrow-right" style="margin-left: 8px;"></i></a>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="footer-content">
                <a href="/" class="logo" id="footer-logo">
                    &lt;A/&gt; ardyan<span>.web.id</span>
                </a>
                <div class="footer-copyright">
                    &copy; 2026 Ardyan. All rights reserved. <span style="opacity: 0.5; margin-left: 8px;">| Last Updated: 27 June 2026</span>
                </div>
                <div class="footer-links">
                    <a href="/#about" id="footer-about">About</a>
                    <a href="/#services" id="footer-services">Services</a>
                    <a href="/#portfolio" id="footer-portfolio">Projects</a>
                    <a href="/publications" id="footer-publications">Publications</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Client-side script for standard interactions -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            // Mobile menu toggle
            const menuToggle = document.getElementById('menu-toggle');
            const navLinks = document.getElementById('nav-links');

            if (menuToggle && navLinks) {
                menuToggle.addEventListener('click', () => {
                    navLinks.classList.toggle('active');
                    menuToggle.classList.toggle('active');
                });
            }

            // Glow Cursor effect
            const cursorGlow = document.getElementById('custom-cursor-glow');
            if (cursorGlow) {
                document.addEventListener('mousemove', (e) => {
                    cursorGlow.style.left = `${e.clientX}px`;
                    cursorGlow.style.top = `${e.clientY}px`;
                });
            }
        });
    </script>
</Layout>

<style is:global>
    /* Hover effects for Back button */
    .back-link-hover:hover {
        transform: translateX(-4px);
        color: var(--color-accent-hover) !important;
    }

    /* Styling for rendered Markdown text inside article-content */
    .article-content h2 {
        font-family: var(--font-heading);
        font-size: 26px;
        font-weight: 800;
        color: var(--color-text-dark);
        margin: 40px 0 16px 0;
        letter-spacing: -0.5px;
    }

    .article-content h3 {
        font-family: var(--font-heading);
        font-size: 20px;
        font-weight: 800;
        color: var(--color-text-dark);
        margin: 32px 0 12px 0;
    }

    .article-content p {
        margin-bottom: 24px;
        color: var(--color-text-muted-dark);
    }

    .article-content ul, .article-content ol {
        margin-bottom: 24px;
        padding-left: 20px;
        color: var(--color-text-muted-dark);
    }

    .article-content li {
        margin-bottom: 8px;
    }

    .article-content blockquote {
        border-left: 4px solid var(--color-ai-indigo);
        background: rgba(99, 102, 241, 0.03);
        padding: 16px 24px;
        margin: 32px 0;
        border-radius: 0 8px 8px 0;
        font-style: italic;
        color: var(--color-text-dark);
    }

    .article-content a {
        color: var(--color-ai-indigo);
        text-decoration: none;
        border-bottom: 1px dashed var(--color-ai-indigo);
        transition: all 0.2s ease;
    }

    .article-content a:hover {
        border-bottom-style: solid;
        color: var(--color-ai-purple);
        border-bottom-color: var(--color-ai-purple);
    }

    .article-content img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 32px 0;
        border: 1px solid var(--color-light-border);
    }

    .article-content code {
        background: rgba(99, 102, 241, 0.05);
        color: var(--color-ai-indigo);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: monospace;
    }

    .article-content pre {
        background: rgba(0, 0, 0, 0.02);
        border: 1px solid var(--color-light-border);
        padding: 20px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 32px 0;
    }

    .article-content pre code {
        background: none;
        color: var(--color-text-dark);
        padding: 0;
        font-size: 14px;
    }

    .article-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 32px 0;
        font-size: 15px;
        line-height: 1.5;
        border: 1px solid var(--color-light-border);
        border-radius: 8px;
        overflow: hidden;
    }

    .article-content th, .article-content td {
        padding: 14px 16px;
        text-align: left;
        border-bottom: 1px solid var(--color-light-border);
    }

    .article-content th {
        background-color: rgba(99, 102, 241, 0.04);
        color: var(--color-text-dark);
        font-weight: 800;
        font-family: var(--font-heading);
    }

    .article-content td {
        color: var(--color-text-muted-dark);
    }

    .article-content tr:last-child td {
        border-bottom: none;
    }

    .article-content tr:nth-child(even) {
        background-color: rgba(0, 0, 0, 0.01);
    }
</style>
